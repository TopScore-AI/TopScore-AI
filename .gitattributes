# Default to LF, detect binaries automatically
* text=auto eol=lf

# Windows-only scripts keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Shell scripts must be LF
*.sh    text eol=lf
gradlew text eol=lf

# Binary assets
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.icns  binary
*.pdf   binary
*.zip   binary
*.jar   binary
*.keystore binary
*.jks   binary
*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
*.mp3   binary
*.mp4   binary
*.wav   binary
