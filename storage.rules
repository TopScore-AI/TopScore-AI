rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 1. RESOURCES: Read-Only for Logged-in Users
    // Students can VIEW, but cannot DELETE or DOWNLOAD without being logged in
    match /resources/{allPaths=**} {
      allow read: if request.auth != null; 
      allow write: if false; // Only admin (you) can upload via Console
    }

    // 2. USER UPLOADS: Any logged-in user can read (images are shared in chats),
    //    but only the owner can write/upload.
    //    GUESTS: Allowed to upload to a specific 'guest' path without auth.
    match /uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null || userId == 'guest';
      allow write: if (request.auth != null && request.auth.uid == userId) || userId == 'guest';
    }

    // 3. Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
