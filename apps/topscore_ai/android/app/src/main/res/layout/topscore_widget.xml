<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/launch_background"
    android:padding="16dp">

    <ImageView
        android:id="@+id/widget_logo"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@mipmap/launcher_icon" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/widget_logo"
        android:layout_marginStart="8dp"
        android:layout_alignTop="@id/widget_logo"
        android:layout_alignBottom="@id/widget_logo"
        android:gravity="center_vertical"
        android:text="Daily Goal"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/study_subject"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_logo"
        android:layout_marginTop="12dp"
        android:text="Next study: Biology"
        android:textColor="#94A3B8"
        android:textSize="12sp" />

    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_below="@id/study_subject"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@android:drawable/progress_horizontal" />

    <TextView
        android:id="@+id/study_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/progress_bar"
        android:layout_marginTop="4dp"
        android:text="0/30 mins completed"
        android:textColor="#64748B"
        android:textSize="10sp" />

</RelativeLayout>
